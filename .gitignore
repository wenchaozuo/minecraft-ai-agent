# Minecraft 智能体项目 .gitignore

# 依赖
node_modules/
package-lock.json

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo

# 缓存/日志
auth_cache/
*.log
*.tmp

# 纹理资源（体积大，不建议放 git）
textures/

# 系统文件
.DS_Store
Thumbs.db

# WorkBuddy
.workbuddy/
.claude/

# 项目无关文件
*.docx
*.doc
NVIDIA Corporation/
